{
    "name": "tims/flipkart-seller-api-php",
    "description": "PHP client for Flipkart Seller APIs",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "flipkart",
        "seller-api",
        "marketplace",
        "sdk",
        "ecommerce"
    ],
    "authors": [
        {
            "name": "TIMS",
            "homepage": "https://github.com/timslabs"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Flipkart\\SellerApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flipkart\\SellerApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
